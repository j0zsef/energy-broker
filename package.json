{
  "name": "@energy-broker",
  "version": "0.0.1",
  "license": "MIT",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "build": "nx run-many --target=build --all",
    "ci-test": "nx reset && nx run-many -t typecheck,lint,test",
    "clean": "nx reset && rm -rf ./dist ./tmp",
    "serve": "nx run-many --target=serve --all",
    "start-dev": "pnpm db-setup && pnpm serve",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "e2e": "nx run frontend-e2e:e2e",
    "e2e:coverage": "CYPRESS_COVERAGE=true nx run frontend-e2e:e2e",
    "open-cypress": "nx run frontend-e2e:open-cypress",
    "db-setup": "docker compose up -d --wait mysql && pnpm prisma-migrate && pnpm db-seed",
    "db-reset": "docker compose down && docker compose up -d --wait mysql && pnpm prisma-migrate && pnpm db-seed",
    "db-seed": "prisma db seed",
    "prisma-migrate": "prisma migrate dev",
    "prisma-generate": "prisma generate",
    "prisma-studio": "prisma studio",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
